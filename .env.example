# auto: 有真实配置时走 SDK，无配置时自动回退到本地 mock
# sdk: 强制走 SDK，请求失败时直接暴露错误，适合验证
# mock: 强制走本地样板数据
REACT_APP_QEECLAW_MODE=auto

# 本地验证可直接使用 Core SDK 自带 mock server
# 客户本地使用时，也可以不改这里，启动后直接在页面内填写 baseUrl + API Key
REACT_APP_QEECLAW_BASE_URL=http://127.0.0.1:3456
REACT_APP_QEECLAW_API_KEY=sk-mock-token

# runtimeType 固定为 openclaw
# 默认工作空间会根据 API Key 自动识别，无需额外配置 teamId / agentId
REACT_APP_QEECLAW_SCOPE=mine
