# QeeClaw Ruisi 前端环境变量模板
# 复制为 .env.local 后按需修改

# ================================================
# 运行模式
# auto: 有真实配置时走 SDK，无配置时自动回退到本地 mock
# sdk: 强制走 SDK，请求失败时直接暴露错误，适合验证
# mock: 强制走本地样板数据
# ================================================
REACT_APP_QEECLAW_MODE=auto

# ================================================
# Runtime 类型（hermes 或 openclaw）
# hermes: 本地单机 Hermes Agent 模式（默认）
# openclaw: 云端 QeeClaw PaaS 模式
# ================================================
REACT_APP_QEECLAW_RUNTIME_TYPE=hermes

# ================================================
# Hermes Bridge 地址
# 仅在 runtimeType=hermes 时有效
# 默认 http://127.0.0.1:21747
# 如果 Bridge 部署在远程服务器，填写对应 IP:PORT
# ================================================
REACT_APP_HERMES_BRIDGE_URL=http://127.0.0.1:21747

# ================================================
# 云端 PaaS 平台地址与 API Key
# 仅在 runtimeType=openclaw 时需要填写
# ================================================
# REACT_APP_QEECLAW_BASE_URL=https://paas.qeeshu.com
# REACT_APP_QEECLAW_API_KEY=sk-your-api-key

# ================================================
# 其他可选配置
# ================================================
REACT_APP_QEECLAW_SCOPE=mine
# REACT_APP_ENABLE_BROWSER_DEV_DATA=1
